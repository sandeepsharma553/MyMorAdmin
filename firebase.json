{
  "firestore": [
    { "database": "mymor-australia", "rules": "firestore.mymor-australia.rules" },
    { "database": "(default)", "rules": "firestore.default.rules" }
  ],
  "storage": [
    { "bucket": "mymor-one", "rules": "storage.rules" },
    { "bucket": "mymor-one.firebasestorage.app", "rules": "storage.default.rules" },
    { "bucket": "mymor-one-firestore-backup-aus", "rules": "storage.backup-aus.rules" }
  ],
  "hosting": [
    {
      "target": "dev",
      "public": "build",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "/firebase-messaging-sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Service-Worker-Allowed", "value": "/" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/firebase-messaging-sw.js", "destination": "/firebase-messaging-sw.js" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "prod",
      "public": "build",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "/firebase-messaging-sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" },
            { "key": "Service-Worker-Allowed", "value": "/" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/firebase-messaging-sw.js", "destination": "/firebase-messaging-sw.js" },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
