rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
   function isSignedIn() { return request.auth != null; }
    function userHostelId() { return isSignedIn() ? request.auth.token.hostelId : null; }
    function hostelActive(hid) {
      return get(/databases/$(db)/documents/hostel/$(hid)).data.active == true;
    }

    // Superadmin-only
    match /hostel/{hid} {
      allow read, write: if isSignedIn() && request.auth.token.role == 'superadmin';
    }
     match /adminMenuState/{uid}/menus/{menuKey} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
    // Employees (hostel admins)
    match /employees/{empId} {
      // Employee doc must belong to same hostel & hostel must be active
      allow read, write: if isSignedIn()
        && resource.data.hostelid == userHostelId()
        && hostelActive(userHostelId());
    }

    // Students / Users etc. (example)
    match /users/{uid} {
      allow read, write: if isSignedIn()
        && resource.data.hostelid == userHostelId()
        && hostelActive(userHostelId());
    }

  match /emailVerifications/{email} {
      allow read, write: if true;
    }
    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
     match /events/{eventId} {
      allow read: if request.auth != null; // only logged-in users
    }

    match /eventBookings/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /User/{userId} {
      allow read: if request.auth.uid == userId;
    }

    match /eventcategory/{docId} {
      allow read: if true; // or restrict as needed
    }
    match /University/{document} {
      allow read,write: if true; // For testing only. Lock down for production!
    }
    
     match /{document=**} {
      allow read, write: if true;
    }
    match /hostel/{hostelId} {
     allow delete: if request.auth != null && resource.data.adminUID == null;
     allow create, update: if request.auth.token.type == "superadmin";
    }
    match /discoverfile/{uid}/{allPaths=**} { allow write: if request.auth.uid == uid; }
  }
}